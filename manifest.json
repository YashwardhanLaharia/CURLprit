{
  "manifest_version": 3,
  "name": "CURLprit",
  "version": "1.0",
  "description": "Converts in-session browser requests to curl commands, enabling bulk downloads of gated content (authorized only)",
  "permissions": ["debugger", "tabs", "activeTab", "storage", "cookies"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
